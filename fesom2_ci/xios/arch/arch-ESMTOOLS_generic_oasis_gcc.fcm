%CCOMPILER      ${CC} 
%FCOMPILER      ${MPIFC}
%LINKER         ${MPIFC}

%BASE_CFLAGS    -ansi -w -fPIC -std=c++11
%PROD_CFLAGS    -O3 -D BOOST_DISABLE_ASSERTS
%DEV_CFLAGS     -g -traceback
%DEBUG_CFLAGS   -DBZ_DEBUG -g -traceback -fno-inline

%BASE_FFLAGS    -D__NONE__ -fPIC
%PROD_FFLAGS    -O3
%DEV_FFLAGS     -g -O2 -traceback
%DEBUG_FFLAGS   -g -traceback

%BASE_INC       -D__NONE__
%BASE_LD        -lstdc++ -fPIC

%CPP            ${CC} -EP
%FPP            cpp -P
%MAKE           gmake
